# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit credentials.

# --- Database ---
DB_HOST=WINSVRSQL03.hostserv.co.za,1433
DB_USERNAME=madprospects
DB_PASSWORD=***REDACTED-DB-PASS***
DB_DATABASE=madauthor

# --- SMTP (DreamHost or any provider) ---
SMTP_HOST=smtp.dreamhost.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_ADDRESS=no-reply@example.com
SMTP_FROM_NAME=MADAuthor

# --- JWT ---
# Generate a strong random string: at least 64 chars. Rotate periodically.
JWT_SIGNING_KEY=replace-with-a-long-random-secret-at-least-64-characters-long
JWT_ISSUER=madauthor
JWT_AUDIENCE=madauthor-web
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=14

# --- File storage ---
# Phase 1: local filesystem. Absolute path is recommended.
STORAGE_PROVIDER=Local
STORAGE_LOCAL_ROOT=C:\Code\madauthor\storage

# --- Worker ---
# Identifier the worker uses when claiming jobs. Defaults to {COMPUTERNAME}-{PID}.
WORKER_ID=

# --- Unsplash (free royalty-free photos for book covers) ---
# Get a free Access Key at https://unsplash.com/developers — no credit card.
# Free tier: 50 req/hr unauthenticated, 5000/hr authenticated. We only need authenticated.
# Per Unsplash API guidelines, attribution to the photographer is required and is rendered
# on the title page of PDF/EPUB exports automatically.
UNSPLASH_ACCESS_KEY=
UNSPLASH_APP_NAME=MADAuthor

ConnectionStrings__Default=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madauthor;User Id=madprospects;Password=***REDACTED-DB-PASS***;TrustServerCertificate=True;
ConnectionStrings__Hangfire=Server=WINSVRSQL03.hostserv.co.za,1433;Database=madauthorhangfire;User Id=madprospects;Password=***REDACTED-DB-PASS***;TrustServerCertificate=True;
DB_PORT=1433
DB_USER=madprospects
DB_PASS=***REDACTED-DB-PASS***
DB_NAME=madauthor

