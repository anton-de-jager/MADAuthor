<?xml version="1.0" encoding="utf-8"?>
<!--
    IIS hosting config for MADAuthor on a Windows server with the .NET 8 Hosting Bundle.

    Prerequisites on the host (one-time):
      1. Install ".NET 8.0 Hosting Bundle" from https://dotnet.microsoft.com/download/dotnet/8.0
         (gives IIS the AspNetCoreModuleV2 it needs to run the app in-process).
      2. In IIS Manager, the app pool for this site should be set to "No Managed Code"
         (.NET CLR version â†’ No Managed Code). ASP.NET Core runs out-of-process from IIS.
      3. The app pool identity needs read/write on the storage/ and logs/ subfolders
         created next to the DLLs.

    This file gets copied verbatim into the publish output by Deploy-Ftp.ps1.

    NOTE on HTTP verbs (DELETE / PUT / PATCH):
      Plesk on Windows + IIS reject these verbs at the server level (locked applicationHost.config),
      and site-level overrides (WebDAVModule remove, requestFiltering verb-allow) silently fail or
      break the whole site config. The API works around this with an HTTP Method Override middleware
      (Program.cs) - the SPA sends POST with an `X-HTTP-Method-Override: DELETE` header. See
      auth.interceptor.ts for the client side and Program.cs for the server-side middleware.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\MadAuthor.Api.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="InProcess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Cross-subdomain refresh cookie. Sets the cookie's Domain on the parent
               so the SPA at madauthor.* can receive a cookie issued by madauthorapi.*.
               Not in the local .env because Domain attribute breaks localhost dev. -->
          <environmentVariable name="COOKIE_DOMAIN" value=".madprospects.com" />
          <!--
            Real secrets (JWT_SIGNING_KEY, DB connection, UNSPLASH_ACCESS_KEY, SMTP_*)
            come from the uploaded .env (the deploy script strips FTP_* before upload).
            If you'd rather keep .env off the server entirely, move them here and tweak
            Deploy-Ftp.ps1 to skip uploading .env.
          -->
          <environmentVariable name="ConnectionStrings__DefaultConnection" value="Server=WINSVRSQL03.hostserv.co.za,1433;Database=madauthor;User Id=madproducts;Password=P@szw0rd;TrustServerCertificate=True;" />
          <environmentVariable name="ConnectionStrings__Default" value="Server=WINSVRSQL03.hostserv.co.za,1433;Database=madauthor;User Id=madproducts;Password=P@szw0rd;TrustServerCertificate=True;" />
          <environmentVariable name="ConnectionStrings__Hangfire" value="Server=WINSVRSQL03.hostserv.co.za,1433;Database=madauthorhangfire;User Id=madproducts;Password=P@szw0rd;TrustServerCertificate=True;" />
          <environmentVariable name="DB_HOST" value="WINSVRSQL03.hostserv.co.za,1433" />
          <environmentVariable name="DB_USERNAME" value="madproducts" />
          <environmentVariable name="DB_PASSWORD" value="P@szw0rd" />
          <environmentVariable name="DB_DATABASE" value="madauthor" />
          <environmentVariable name="DB_HANGFIRE_DATABASE" value="madauthorhangfire" />
          <environmentVariable name="DB_USER" value="madproducts" />
          <environmentVariable name="DB_PASS" value="P@szw0rd" />
          <environmentVariable name="DB_NAME" value="madauthor" />
          <environmentVariable name="DB_PORT" value="1433" />
          <environmentVariable name="JWT_SIGNING_KEY" value="DHnCzOPw525bEi9lSRfHlU02GzX1+wVPsw8r+xstjec9MQPamaMIiW8e4Wm16gDrK3HprBOj4YAQh1ct9OLRtA==" />
          <environmentVariable name="CLAUDE_WORKER_TOKEN" value="fbecdf4218aef76b63dd23c4c221490abb15b2485fc912fbc9746bc2ced68a18" />
          <environmentVariable name="SMTP_HOST" value="smtp.dreamhost.com" />
          <environmentVariable name="SMTP_PORT" value="465" />
          <environmentVariable name="SMTP_SECURE" value="true" />
          <environmentVariable name="SMTP_USER" value="admin@madleads.ai" />
          <environmentVariable name="SMTP_PASS" value="P@szw0rdML" />
          <environmentVariable name="UNSPLASH_ACCESS_KEY" value="rMkMcHfD7MGMl2kPwgYgCrSfuhuwTF7YYoICCVaBBeE" />
          <environmentVariable name="UNSPLASH_SECRET_KEY" value="k_tKMuuhbe5pENOK0IGn90NPDxIOpNfBycoSPMQsWjE" />
          <environmentVariable name="UNSPLASH_APP_NAME" value="MADAuthor" />
          <environmentVariable name="PAYFAST_SANDBOX" value="true" />
          <environmentVariable name="PAYFAST_MERCHANT_ID" value="10049399" />
          <environmentVariable name="PAYFAST_MERCHANT_KEY" value="fy4r8ufw9w0cp" />
          <environmentVariable name="PAYFAST_PASSPHRASE" value="ThisIsForMadProductsTheLast0ne" />
          <environmentVariable name="PAYFAST_PUBLIC_BASE_URL" value="https://madauthorapi.madprospects.com" />
          <environmentVariable name="PAYFAST_RETURN_URL" value="https://madauthor.madprospects.com/billing/success" />
          <environmentVariable name="PAYFAST_CANCEL_URL" value="https://madauthor.madprospects.com/billing/cancelled" />
          <environmentVariable name="PAYFAST_NOTIFY_URL" value="https://madauthorapi.madprospects.com/api/payments/payfast/notify" />
          <environmentVariable name="PAYFAST_FALLBACK_EMAIL" value="billing@madprospects.com" />
          <environmentVariable name="PAYFAST_PRODUCT_NAME" value="MADAuthor" />
        </environmentVariables>
      </aspNetCore>
      <!-- Keep the default static-file MIME types but ensure .json works. -->
      <staticContent>
        <remove fileExtension=".json" />
        <mimeMap fileExtension=".json" mimeType="application/json" />
      </staticContent>
      <!-- Avoid the FTP-edit dance of the auto-generated machine key - make it sticky. -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>